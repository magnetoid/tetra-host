# Tetra Host console (Next.js) — copy to .env.local for development.

# Where the FastAPI control plane's JSON contract lives. The console proxies all
# browser calls through /api/proxy/* to this base (see src/lib/api.ts).
BACKEND_API_BASE_URL=http://127.0.0.1:8088/api/v1

# Shown in the sidebar environment chip: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Public origin of this console (absolute URLs, auth redirects).
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Public origin of the FastAPI panel (e.g. https://panel.cloud-industry.com). Used
# for browser-redirect flows that must run on the panel's origin/session — today the
# OIDC "Open webmail" launch. Leave empty to hide the button. Note: the OIDC flow
# authenticates against the PANEL session, so the button opens the panel origin.
PANEL_PUBLIC_URL=

# Optional: browser error reporting to the platform's GlitchTip (Sentry-compatible DSN).
# Leave empty to disable — the SDK is only loaded when set.
NEXT_PUBLIC_GLITCHTIP_DSN=
