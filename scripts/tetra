#!/usr/bin/env bash
# Run tetra-cli without installing it. Prefers the project venv.
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PY="$DIR/.venv/bin/python"
[[ -x "$PY" ]] || PY="$(command -v python3)"
exec env PYTHONPATH="$DIR${PYTHONPATH:+:$PYTHONPATH}" "$PY" -m tetra_cli "$@"
