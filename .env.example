APP_NAME="Cloud Industry Hosting"
APP_ENV=development
APP_SECRET=change-me-generate-with-openssl-rand-hex-32
# text (human-readable, default) or json (structured, for log aggregation)
LOG_FORMAT=text
BASE_URL=http://127.0.0.1:8088
DATABASE_URL=sqlite+aiosqlite:///./data/tetra_host.db
REDIS_URL=
ALLOWED_HOSTS_RAW=127.0.0.1,localhost,testserver
SESSION_COOKIE_NAME=tetra_host_session
SESSION_MAX_AGE_SECONDS=43200
SESSION_HTTPS_ONLY=false
SESSION_SAME_SITE=lax
# Origin-based CSRF backstop for the browser/session surface (blocks cross-site
# unsafe requests before they hit a handler). /api, /graphql, OIDC-token, and
# any Bearer client are always exempt. Leave on unless you have a specific need.
CSRF_PROTECT=true
FORCE_HTTPS_REDIRECT=false
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
REQUEST_TIMEOUT_SECONDS=20
PROVIDER_CACHE_TTL_SECONDS=30
ENABLE_PROVIDER_ACTIONS=false
COOLIFY_URL=https://coolify.example.com
COOLIFY_TOKEN=
MAILCOW_URL=https://mail.example.com
MAILCOW_API_KEY=
# Set false when Mailcow uses a self-signed cert on a loopback endpoint
# (e.g. co-located at https://127.0.0.1:8480). Default true.
MAILCOW_VERIFY_TLS=true
# Mail platform (Phase 2). MAIL_HOSTNAME = the dedicated Mailcow host FQDN (MX target);
# empty skips the MX record in DNS automation. SPF/DMARC contents are configurable so an
# ESP include can be added (e.g. "v=spf1 mx include:spf.mtasv.net ~all" for Postmark).
# MAIL_DEFAULT_RELAYHOST_ID: a mailcow relayhost id to auto-assign to new mail domains
# (create one with `tetra mail relayhost add`); 0 = no outbound relay.
MAIL_HOSTNAME=
MAIL_SPF_RECORD="v=spf1 mx ~all"
MAIL_DMARC_RECORD="v=DMARC1; p=quarantine"
MAIL_DEFAULT_RELAYHOST_ID=0

# OIDC Identity Provider — passwordless webmail SSO (Tetra is the IdP, Mailcow the
# client). Dormant unless ALL of issuer + key + client + redirect are set. Generate
# the key with scripts/gen-oidc-key.sh; configure the matching client inside Mailcow
# (System > Configuration > Access > Identity Provider > Generic-OIDC). Full guide:
# docs/OIDC_WEBMAIL_SSO.md.
OIDC_ISSUER=
OIDC_PRIVATE_KEY_PEM=
OIDC_CLIENT_ID=mailcow
OIDC_CLIENT_SECRET=
# Comma-separated exact-match allowlist of Mailcow OIDC callback URLs.
OIDC_REDIRECT_URIS_RAW=
# Where the console's "Open webmail" button sends the browser to start SSO.
OIDC_WEBMAIL_URL=
CLOUDFLARE_API_TOKEN=
# Umami web analytics (self-hosted v2) — powers the project Metrics tab. Leave URL
# empty to disable (the tab shows a "connect analytics" state).
UMAMI_URL=
UMAMI_USERNAME=
UMAMI_PASSWORD=
# GlitchTip error tracking (Sentry-API-compatible) — powers the project Errors tab.
# Leave URL empty to disable. Token = a GlitchTip auth token; ORG = the org slug.
GLITCHTIP_URL=
GLITCHTIP_TOKEN=
GLITCHTIP_ORG=

# Image registry for rollback durability. Leave empty to keep built images local-only
# (rollback then depends on images not being pruned). Set to host:port of a Docker
# registry (e.g. 127.0.0.1:5000 — run one with scripts/install-registry.sh) to push
# every successful build; rollback re-pulls evicted images. KEEP_IMAGES bounds the
# per-project rollback window.
REGISTRY_URL=
REGISTRY_KEEP_IMAGES=5

# AI-assisted build-failure diagnosis ("tetra ai explain"). Leave the key empty to run
# the deterministic heuristic analyzer only (no LLM); set it to enrich failed-build
# diagnoses via the Anthropic Messages API (best-effort, falls back to the heuristic).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

ADMIN_BOOTSTRAP_EMAIL=admin@cloud-industry.com
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME="Platform Admin"

# Production minimums:
# APP_ENV=production
# BASE_URL=https://panel.cloud-industry.com
# ALLOWED_HOSTS_RAW=panel.cloud-industry.com,127.0.0.1,localhost,testserver
# SESSION_HTTPS_ONLY=true
# FORCE_HTTPS_REDIRECT=true
